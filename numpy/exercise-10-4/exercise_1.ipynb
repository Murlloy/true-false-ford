    "import numpy as np\n",
    "\n",
    "a = np.array([10,20,30,40,50])\n",
    "b = np.array([1,2,3,4,5])\n",
    "\n",
    "print(f\"Multiplicação: {np.multiply(a,b)}\")\n",
    "print(f\"Soma: {np.add(a,b)}\")\n",
    "print(f\"Subtração: {np.subtract(a,b)}\")\n",
    "print(f\"Divisão: {np.divide(a,b)}\")"
   ]
  }
